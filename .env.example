# MinerU cloud API token (create at https://mineru.net -> API Management)
MINERU_API_TOKEN=

# Obsidian vault root — .raw/<citekey>/ and attachments/papers/<citekey>/ will be created here
VAULT_ROOT=

# Reuse zotero-mcp's local mode (reads ~/Zotero/zotero.sqlite for PDF paths)
# Must match how you run zotero-mcp
ZOTERO_LOCAL=true

# Optional: override MinerU base URL
# MINERU_BASE_URL=https://mineru.net

# Optional: log level (DEBUG/INFO/WARNING/ERROR)
MINERU_ZOTERO_LOG_LEVEL=WARNING
